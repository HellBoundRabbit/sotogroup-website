{
  "firestore": {
    "rules": "miscellaneous-development-files/firestore.rules",
    "indexes": "miscellaneous-development-files/firestore.indexes.json"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "functions/**",
      "functions1/**",
      "miscellaneous-development-files/**",
      "miscellaneous-development-files/google-cloud-sdk/**",
      "miscellaneous-development-files/*.tar.gz",
      "*.mov",
      "firebase-debug.log",
      "firebase-debug*.log"
    ],
    "rewrites": [{ "source": "/login", "destination": "/pages/soto-routes-login.html" }],
    "headers": [
      {
        "source": "**/*.@(html|htm)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ]
  },
  "functions": { "source": "functions" },
  "storage": [{ "bucket": "soto-routes.firebasestorage.app", "rules": "storage.rules" }]
}
